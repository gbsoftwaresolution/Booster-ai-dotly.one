# ─────────────────────────────────────────────────────────────────────────────
# Dotly.one — environment variables reference
# Copy this file to .env and fill in all values before running the app.
# See docs/ENVIRONMENT.md for detailed descriptions.
#
# IMPORTANT: variable names here match the canonical names used by the API
# (apps/api/src/config/env.validation.ts).  Do NOT use the old aliases that
# appeared in older docs:
#   R2_BUCKET_NAME         → use R2_BUCKET
#   MAILGUN_FROM           → use MAILGUN_FROM_EMAIL
#   AWS_SES_ACCESS_KEY_ID  → use AWS_SES_ACCESS_KEY
#   AWS_SES_SECRET_ACCESS_KEY → use AWS_SES_SECRET_KEY
#   AWS_SES_FROM           → use AWS_SES_FROM_EMAIL
#   RPC_URL_POLYGON        → use POLYGON_RPC_URL
#   RPC_URL_BASE           → use BASE_RPC_URL
#   CONTRACT_ADDRESS_POLYGON → use DOTLY_CONTRACT_ADDRESS
#   CORS_ORIGIN            → use CORS_ORIGINS (comma-separated list)
#   NEXT_PUBLIC_APP_URL    → use NEXT_PUBLIC_WEB_URL (web) and WEB_URL (api)
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Prisma format)
DATABASE_URL=postgresql://user:password@localhost:5432/dotly_one

# ── Redis ────────────────────────────────────────────────────────────────────
# Used for BullMQ job queues and rate-limiting
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
# First-party JWT signing secret used by the API
AUTH_JWT_SECRET=generate-a-unique-random-secret
# Google OAuth for user sign-in
GOOGLE_AUTH_CLIENT_ID=your-google-auth-client-id
GOOGLE_AUTH_CLIENT_SECRET=your-google-auth-client-secret
GOOGLE_AUTH_STATE_SECRET=generate-a-unique-random-secret

# ── NestJS API ───────────────────────────────────────────────────────────────
# Port the API server listens on (default 3001)
PORT=3001
# Canonical base URL of the Next.js web app (used by API for CORS and email links)
WEB_URL=http://localhost:3000
# Allowed CORS origins — comma-separated list; WEB_URL is always included
CORS_ORIGINS=http://localhost:3000

# ── Next.js Web ──────────────────────────────────────────────────────────────
# Public URL of the NestJS API, consumed by the browser
NEXT_PUBLIC_API_URL=http://localhost:3001
# Internal API URL used by Next.js server components (may differ in production when on same private network)
# server-api.ts reads API_URL first, then falls back to INTERNAL_API_URL.
API_URL=http://localhost:3001
INTERNAL_API_URL=http://localhost:3001
# Public URL of the Next.js app itself (used for absolute links, OG images, etc.)
# NOTE: middleware.ts reads NEXT_PUBLIC_APP_URL; keep both in sync with NEXT_PUBLIC_WEB_URL
NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Canonical site URL used for card share meta tags and Open Graph (card/[handle]/page.tsx, ShareBar.tsx)
# In production set to https://dotly.one (or your custom domain)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Cloudflare R2 (file storage) ─────────────────────────────────────────────
# Used for avatar uploads, media blocks, and QR code images
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# Canonical bucket name (env.validation.ts uses R2_BUCKET)
R2_BUCKET=dotly-uploads
# Public base URL for serving uploaded files
R2_PUBLIC_URL=https://pub-xxxx.r2.dev
# Inbox direct-upload token signing secret
INBOX_UPLOAD_TOKEN_SECRET=generate-a-unique-random-secret

# ── Email ─────────────────────────────────────────────────────────────────────
# Primary: Mailgun
MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAILGUN_DOMAIN=mg.yourdomain.com
MAILGUN_FROM_EMAIL=no-reply@mg.yourdomain.com
# Fallback: Amazon SES (used when Mailgun fails)
AWS_SES_REGION=us-east-1
AWS_SES_ACCESS_KEY=your-aws-access-key-id
AWS_SES_SECRET_KEY=your-aws-secret-access-key
AWS_SES_FROM_EMAIL=no-reply@yourdomain.com

# ── Blockchain / On-chain billing ─────────────────────────────────────────────
# RPC URLs for the networks where DotlySubscription.sol is deployed
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your-key
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/your-key
# Deployed contract address (a single address is used; deploy to one primary chain)
DOTLY_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Internal support refund tooling
DOTLY_SUPPORT_OPS_KEY=generate-a-unique-random-secret
DOTLY_SUPPORT_OPS_EMAILS=support@example.com,ops@example.com

# ── BoosterAI Affiliate Billing ───────────────────────────────────────────────
BOOSTERAI_API_URL=https://api.boosterai.space
BOOSTERAI_INTERNAL_API_KEY=your-boosterai-internal-api-key
BOOSTERAI_DOTLY_API_KEY=your-boosterai-dotly-api-key
BOOSTERAI_COUNTRY_CODE=US
# planId mapping (defaults match BoosterAI catalogue; only set if catalogue changes)
BOOSTERAI_PLAN_ID_STARTER=1
BOOSTERAI_PLAN_ID_PRO=2
BOOSTERAI_PLAN_ID_BUSINESS=3
BOOSTERAI_PLAN_ID_AGENCY=4
BOOSTERAI_PLAN_ID_ENTERPRISE=5

# ── BoosterAI PaymentVault — web client reference ─────────────────────────────
NEXT_PUBLIC_PAYMENT_VAULT_ADDRESS=0x952257d729e49707f7692B870fC93bf182824Fb2

# ── Expo / Mobile push notifications ─────────────────────────────────────────
# Expo push notification access token (for sending push via Expo's service)
EXPO_ACCESS_TOKEN=your-expo-access-token

# ── Expo Mobile app (apps/mobile) ─────────────────────────────────────────────
# These vars are bundled into the native binary at EAS build time.
# EXPO_PUBLIC_* vars are inlined at build time — never put secrets here.
#
# Base URL of the NestJS API reachable from the device (must be HTTPS in prod)
EXPO_PUBLIC_API_URL=http://localhost:3001
# EAS project ID — find in eas.json or expo.dev dashboard (used for push token registration)
EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id

# ── OpenAI (AI enrichment) ────────────────────────────────────────────────────
# Used by the contact enrichment BullMQ worker
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Error tracking ────────────────────────────────────────────────────────────
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

# ── Analytics ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── Apple Wallet pass generation (optional) ───────────────────────────────────
# Required only if you want to offer Apple Wallet passes.
# Leave blank to disable — endpoints will return 400 if unset.
APPLE_PASS_TYPE_ID=pass.com.yourcompany.dotly
APPLE_TEAM_ID=ABCDEF1234
# Base-64 encoded .p12 certificate bundle (openssl base64 -in pass.p12)
APPLE_PASS_CERT_P12=
# Passphrase for the .p12 certificate
APPLE_PASS_CERT_PASS=

# ── Google Wallet pass generation (optional) ──────────────────────────────────
# Required only if you want to offer Google Wallet passes.
# Leave blank to disable — endpoints will return 400 if unset.
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_SERVICE_ACCOUNT_EMAIL=dotly@your-project.iam.gserviceaccount.com
# Base-64 encoded service account JSON key (base64 -w0 service-account.json)
GOOGLE_WALLET_SERVICE_ACCOUNT_KEY=

# Google OAuth state signing secret for scheduling integration
GOOGLE_OAUTH_STATE_SECRET=generate-a-unique-random-secret

# Webhook secret encryption key
WEBHOOK_SECRET_ENCRYPTION_KEY=generate-a-unique-random-secret
