# ─────────────────────────────────────────────────────────────────────────────
# Dotly.one — environment variables reference
# Copy this file to .env and fill in all values before running the app.
# See docs/ENVIRONMENT.md for detailed descriptions.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Prisma format)
DATABASE_URL=postgresql://user:password@localhost:5432/dotly_one

# ── Redis ────────────────────────────────────────────────────────────────────
# Used for BullMQ job queues and rate-limiting
REDIS_URL=redis://localhost:6379

# ── Supabase ─────────────────────────────────────────────────────────────────
# Project URL — find in Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Anon/public key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# JWT secret — used by the NestJS API to verify Supabase-issued JWTs
# Find in Supabase dashboard → Settings → API → JWT Settings
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ── NestJS API ───────────────────────────────────────────────────────────────
# Port the API server listens on (default 3001)
PORT=3001
# Allowed CORS origins (comma-separated)
CORS_ORIGIN=http://localhost:3000

# ── Next.js Web ──────────────────────────────────────────────────────────────
# Public URL of the NestJS API, consumed by the browser
NEXT_PUBLIC_API_URL=http://localhost:3001
# Public URL of the Next.js app itself (used for absolute links, OG images, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Cloudflare R2 (file storage) ─────────────────────────────────────────────
# Used for avatar uploads, media blocks, and QR code images
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=dotly-uploads
# Public base URL for serving uploaded files
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ── Email ─────────────────────────────────────────────────────────────────────
# Primary: Mailgun
MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAILGUN_DOMAIN=mg.yourdomain.com
MAILGUN_FROM=Dotly <no-reply@mg.yourdomain.com>
# Fallback: Amazon SES (used when Mailgun fails)
AWS_SES_REGION=us-east-1
AWS_SES_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SES_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_SES_FROM=Dotly <no-reply@yourdomain.com>

# ── Blockchain / On-chain billing ─────────────────────────────────────────────
# RPC URLs for the networks where DotlySubscription.sol is deployed
RPC_URL_POLYGON=https://polygon-mainnet.g.alchemy.com/v2/your-key
RPC_URL_BASE=https://base-mainnet.g.alchemy.com/v2/your-key
# Deployed contract addresses (per network)
CONTRACT_ADDRESS_POLYGON=0x0000000000000000000000000000000000000000
CONTRACT_ADDRESS_BASE=0x0000000000000000000000000000000000000000

# ── Expo / Mobile push notifications ─────────────────────────────────────────
# Expo push notification access token (for sending push via Expo's service)
EXPO_ACCESS_TOKEN=your-expo-access-token

# ── OpenAI (AI enrichment) ────────────────────────────────────────────────────
# Used by the contact enrichment BullMQ worker
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
