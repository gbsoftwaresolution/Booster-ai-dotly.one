generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Plan {
  FREE
  STARTER
  PRO
  BUSINESS
  AGENCY
  ENTERPRISE
}

enum BillingDuration {
  MONTHLY
  SIX_MONTHS
  ANNUAL
}

enum VcardPolicy {
  PUBLIC
  MEMBERS_ONLY
}

enum CardTemplate {
  MINIMAL
  BOLD
  CREATIVE
  CORPORATE
  ELEGANT
  DARK
  NEON
  RETRO
  GLASSMORPHISM
}

enum ContactStage {
  NEW
  CONTACTED
  QUALIFIED
  CLOSED
  LOST
}

enum AnalyticsEventType {
  VIEW
  CLICK
  SAVE
  LEAD_SUBMIT
}

enum SocialPlatform {
  LINKEDIN
  TWITTER
  INSTAGRAM
  GITHUB
  YOUTUBE
  TIKTOK
  WHATSAPP
  FACEBOOK
  CALENDLY
  CALCOM
  CUSTOM
}

enum MediaBlockType {
  VIDEO
  IMAGE
  AUDIO
  DOCUMENT
  HEADING
}

enum TeamRole {
  ADMIN
  MEMBER
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  PENDING
}

enum DomainStatus {
  PENDING
  ACTIVE
  FAILED
}

enum LeadFieldType {
  TEXT
  EMAIL
  PHONE
  URL
  TEXTAREA
  SELECT
}

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  URL
  SELECT
}

enum DealStage {
  PROSPECT
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id            String  @id @default(cuid())
  email         String  @unique
  username      String? @unique
  emailVerifiedAt DateTime?
  name          String?
  pitch         String?
  avatarUrl     String?
  plan          Plan    @default(FREE)
  walletAddress String? @unique // crypto billing
  boosterAiPartnerId String? @unique // linked BoosterAI partner identity for self-referral checks
  pushToken     String?
  passwordHash  String?
  googleId      String? @unique
  phone         String?
  /// ISO 3166-1 alpha-2 country code, e.g. "US", "GB", "IN"
  country       String? @db.VarChar(2)
  /// IANA timezone identifier, e.g. "America/New_York", "Asia/Kolkata"
  timezone      String? @db.VarChar(64)
  /// Notification preferences
  notifLeadCaptured  Boolean @default(true)
  notifWeeklyDigest  Boolean @default(true)
  notifProductUpdates Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  cards              Card[]
  contacts           Contact[]
  subscription       Subscription?
  customDomains      CustomDomain[]
  ownedTeams         Team[]       @relation("TeamOwner")
  teamMemberships    TeamMember[]
  auditLogs          AuditLog[]
  webhookEndpoints   WebhookEndpoint[]
  pipelines          Pipeline[]
  contactNotes       ContactNote[]
  contactCustomFields ContactCustomField[]
  emailTemplates     EmailTemplate[]
  deals              Deal[]
  contactTasks       ContactTask[]
  contactAutomationRules ContactAutomationRule[]
  appointmentTypes   AppointmentType[]
  bookings           Booking[]
  bookingDeposits    BookingDeposit[]
  serviceOrders      ServiceOrder[]
  productOrders      ProductOrder[]
  googleCalendar     GoogleCalendarConnection?
  contactMemories    ContactMemory[]
  authSessions       AuthSession[]
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  pendingEmailChanges     PendingEmailChange[]

  @@map("users")
}

model AuthSession {
  id               String   @id @default(cuid())
  userId           String
  refreshTokenHash String
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("auth_sessions")
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

model PendingEmailChange {
  id            String   @id @default(cuid())
  userId        String
  newEmail      String
  tokenHash     String   @unique
  expiresAt     DateTime
  verifiedAt    DateTime?
  cancelledAt   DateTime?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([newEmail])
  @@map("pending_email_changes")
}

model Card {
  id         String       @id @default(cuid())
  userId     String
  handle     String       @unique
  templateId CardTemplate @default(MINIMAL)
  fields     Json         @default("{}")
  isActive     Boolean      @default(false)
  vcardPolicy  VcardPolicy  @default(PUBLIC)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme       CardTheme?
  socialLinks SocialLink[]
  mediaBlocks MediaBlock[]
  qrCode      QrCode?
  analytics   AnalyticsEvent[]
  contacts    Contact[]        @relation("ContactSourceCard")
  customDomains CustomDomain[]
  leadForm    LeadForm?
  walletPass  WalletPass?
  messages         CardMessage[]
  voiceNotes       CardVoiceNote[]
  dropboxFiles     CardDropboxFile[]
  serviceOrders    ServiceOrder[]
  productOrders    ProductOrder[]

  @@index([userId])
  @@map("cards")
}

enum ServiceOrderStatus {
  INTENT_CREATED
  VERIFIED
  COMPLETED
  EXPIRED
}

enum ProductOrderStatus {
  INTENT_CREATED
  VERIFIED
  COMPLETED
  EXPIRED
}

model ServiceOrder {
  id               String             @id @default(cuid())
  cardId           String
  ownerUserId      String
  paymentId        String             @unique @db.VarChar(100)
  serviceId        String             @db.VarChar(100)
  serviceName      String             @db.VarChar(160)
  customerName     String             @db.VarChar(120)
  customerEmail    String             @db.VarChar(254)
  walletAddress    String             @db.VarChar(42)
  recipientAddress String             @db.VarChar(42)
  amountUsdt       String             @db.VarChar(32)
  amountRaw        String             @db.VarChar(64)
  tokenAddress     String             @db.VarChar(42)
  chainId          Int
  notes            String?            @db.VarChar(1000)
  status           ServiceOrderStatus @default(INTENT_CREATED)
  txHash           String?            @unique @db.VarChar(66)
  verifiedAt       DateTime?
  completedAt      DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  card      Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  ownerUser User @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([ownerUserId, status])
  @@index([cardId, status])
  @@map("service_orders")
}

model ProductOrder {
  id               String             @id @default(cuid())
  cardId           String
  ownerUserId      String
  paymentId        String             @unique @db.VarChar(100)
  productId        String             @db.VarChar(100)
  productName      String             @db.VarChar(160)
  customerName     String             @db.VarChar(120)
  customerEmail    String             @db.VarChar(254)
  walletAddress    String             @db.VarChar(42)
  recipientAddress String             @db.VarChar(42)
  amountUsdt       String             @db.VarChar(32)
  amountRaw        String             @db.VarChar(64)
  tokenAddress     String             @db.VarChar(42)
  chainId          Int
  notes            String?            @db.VarChar(1000)
  status           ProductOrderStatus @default(INTENT_CREATED)
  txHash           String?            @unique @db.VarChar(66)
  verifiedAt       DateTime?
  completedAt      DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  card      Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  ownerUser User @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([ownerUserId, status])
  @@index([cardId, status])
  @@map("product_orders")
}

model CardTheme {
  id                String  @id @default(cuid())
  cardId            String  @unique
  primaryColor      String  @default("#000000")
  secondaryColor    String  @default("#ffffff")
  fontFamily        String  @default("Inter")
  backgroundUrl     String?
  logoUrl           String?
  buttonStyle       String?
  socialButtonStyle String?

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@map("card_themes")
}

model SocialLink {
  id           String         @id @default(cuid())
  cardId       String
  platform     SocialPlatform
  url          String
  displayOrder Int            @default(0)

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@map("social_links")
}

model MediaBlock {
  id           String         @id @default(cuid())
  cardId       String
  type         MediaBlockType
  url          String?
  caption      String?
  altText      String?
  linkUrl      String?
  displayOrder Int            @default(0)
  mimeType     String?
  fileSize     Int?
  groupId      String?
  groupName    String?

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@map("media_blocks")
}

model QrCode {
  id          String @id @default(cuid())
  cardId      String @unique
  styleConfig Json   @default("{}")
  shortUrl    String

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@map("qr_codes")
}

model AnalyticsEvent {
  id        String             @id @default(cuid())
  cardId    String
  type      AnalyticsEventType
  metadata  Json               @default("{}")
  ipHash    String?
  country   String?
  device    String?
  referrer  String?
  createdAt DateTime           @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@index([cardId, type])
  @@index([cardId, createdAt])
  @@index([createdAt])
  // Composite index covering the hottest analytics query: filter by card + type + date range.
  // Eliminates full-table scans on getAnalytics / getSummary for high-traffic cards.
  @@index([cardId, type, createdAt])
  @@map("analytics_events")
}

model ClickEvent {
  id        String   @id @default(uuid())
  action    String
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("click_events")
}

model Contact {
  id           String   @id @default(cuid())
  ownerUserId  String
  name         String
  email        String?
  phone        String?
  company      String?
  title        String?
  website      String?
  address      String?
  notes        String?
  tags         String[]
  sourceCardId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // AI Enrichment fields
  inferredIndustry    String?
  inferredCompanySize String?
  inferredSeniority   String?
  inferredLinkedIn    String?
  enrichmentScore     Int?
  enrichmentSummary   String?
  enrichedAt          DateTime?

  ownerUser       User              @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  sourceCard      Card?             @relation("ContactSourceCard", fields: [sourceCardId], references: [id], onDelete: SetNull)
  crmPipeline     CrmPipeline?
  emails          ContactEmail[]
  timeline        ContactTimeline[]
  leadSubmissions LeadSubmission[]
  contactNotes    ContactNote[]
  deals           Deal[]
  tasks           ContactTask[]
  customFieldValues ContactCustomFieldValue[]
  memories          ContactMemory[]

  @@unique([ownerUserId, email])
  @@index([ownerUserId])
  @@index([ownerUserId, createdAt])
  // Analytics queries filter by sourceCardId and often sort/range on createdAt.
  // A compound index avoids a full-table scan on the contacts table at scale.
  @@index([sourceCardId, createdAt])
  @@map("contacts")
}

model CrmPipeline {
  id          String   @id @default(cuid())
  contactId   String   @unique
  stage       String   @default("NEW")
  ownerUserId String
  pipelineId  String?      // nullable — null means "default pipeline"
  updatedAt   DateTime @updatedAt

  contact  Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  pipeline Pipeline? @relation(fields: [pipelineId], references: [id], onDelete: SetNull)

  @@index([ownerUserId, stage])
  @@index([pipelineId])
  @@map("crm_pipeline")
}

model Subscription {
  id                     String             @id @default(cuid())
  userId                 String             @unique
  plan                   Plan               @default(FREE)
  status                 SubscriptionStatus @default(PENDING)
  contractSubscriptionId String? // on-chain subscription ID
  txHash                 String? // on-chain activation transaction hash
  chainId                Int? // 137 = Polygon, 8453 = Base
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean            @default(false)

  // BoosterAI affiliate billing integration
  // Set when the subscription was purchased via BoosterAI's PaymentVault.
  // boosterAiOrderId  — the orderId returned by BoosterAI's POST /v1/orders
  // boosterAiPartnerId — the affiliate partner who referred this user (nullable
  //                      when the user purchased directly with no referral)
  boosterAiOrderId   String? @unique // BoosterAI ord_xxx order ID
  boosterAiPartnerId String? // numeric partnerId as string (BigInt safe)
  billingDuration    BillingDuration? // MONTHLY | SIX_MONTHS | ANNUAL
  amountUsdt         String? // exact USDT amount charged, e.g. "20.00"

  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([boosterAiOrderId])
  @@map("subscriptions")
}

model CustomDomain {
  id                String       @id @default(cuid())
  userId            String
  cardId            String?
  domain            String       @unique
  status            DomainStatus @default(PENDING)
  verificationToken String
  isVerified        Boolean      @default(false)
  sslStatus         String       @default("pending")
  txtRecord         String       @default("")
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card? @relation(fields: [cardId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([domain])
  @@map("custom_domains")
}

model Team {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique // URL-safe lowercase slug derived from name
  ownerUserId String
  brandConfig Json     @default("{}")
  brandLock   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner   User         @relation("TeamOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  members TeamMember[]
  invites TeamInvite[]

  @@index([ownerUserId])
  @@map("teams")
}

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  userId   String
  role     TeamRole @default(MEMBER)
  joinedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
  @@map("team_members")
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  action       String
  resource     String   @default("")
  resourceId   String?
  metadata     Json     @default("{}")
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model ContactEmail {
  id             String    @id @default(cuid())
  contactId      String
  subject        String    @db.VarChar(998)
  body           String    @db.VarChar(50000)
  sentAt         DateTime  @default(now())
  trackingToken  String?   @unique
  openedAt       DateTime?
  clickedAt      DateTime?

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@map("contact_emails")
}

model ContactTimeline {
  id        String   @id @default(cuid())
  contactId String
  event     String
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@map("contact_timeline")
}

model TeamInvite {
  id        String    @id @default(cuid())
  teamId    String
  email     String
  role      TeamRole  @default(MEMBER)
  token     String    @unique
  accepted  Boolean   @default(false)
  expiresAt DateTime
  createdAt DateTime  @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([email])
  @@map("team_invites")
}

// ─── Lead Capture Form (P0.3) ─────────────────────────────────────────────────

// One LeadForm per Card — defines the custom field schema shown on the public card.
model LeadForm {
  id          String      @id @default(cuid())
  cardId      String      @unique
  title       String      @default("Connect with me")
  description String      @default("Leave your details and they'll be in touch.")
  buttonText  String      @default("Connect")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  card        Card          @relation(fields: [cardId], references: [id], onDelete: Cascade)
  fields      LeadField[]
  submissions LeadSubmission[]

  @@map("lead_forms")
}

// Each row is one custom input field on the lead capture form.
model LeadField {
  id           String        @id @default(cuid())
  leadFormId   String
  label        String        @db.VarChar(100)
  fieldType    LeadFieldType @default(TEXT)
  placeholder  String?       @db.VarChar(200)
  required     Boolean       @default(false)
  displayOrder Int           @default(0)
  // For SELECT type — JSON array of option strings, e.g. ["Sales","Marketing","Engineering"]
  options      Json          @default("[]")

  leadForm LeadForm @relation(fields: [leadFormId], references: [id], onDelete: Cascade)

  @@index([leadFormId])
  @@map("lead_fields")
}

// One row per public lead form submission — stores the raw field answers.
// contactId links back to the Contact created at submission time (nullable
// for cases where the contact could not be created, e.g. duplicate email).
model LeadSubmission {
  id         String   @id @default(cuid())
  leadFormId String
  contactId  String?
  // JSON object mapping normalised field label → submitted value
  // e.g. { "name": "Jane", "company": "Acme", "interest": "Sales" }
  answers    Json     @default("{}")
  submittedAt DateTime @default(now())

  leadForm LeadForm @relation(fields: [leadFormId], references: [id], onDelete: Cascade)
  contact  Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([leadFormId])
  @@index([leadFormId, submittedAt])
  @@index([contactId])
  @@map("lead_submissions")
}

// ─── Outbound Webhooks (P0.2) ─────────────────────────────────────────────────

// A webhook endpoint registered by a user (e.g. Zapier catch-hook URL).
model WebhookEndpoint {
  id        String   @id @default(cuid())
  userId    String
  url       String   @db.VarChar(2048)
  // Comma-separated event names e.g. "lead.created,card.viewed"
  events    String[]
  secret    String   // HMAC-SHA256 signing secret (stored hashed in service, raw here for simplicity)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([userId])
  @@map("webhook_endpoints")
}

// Delivery log — one row per webhook fan-out attempt.
model WebhookDelivery {
  id              String   @id @default(cuid())
  endpointId      String
  event           String
  payload         Json
  statusCode      Int?
  responseBody    String?  @db.VarChar(2000)
  durationMs      Int?
  success         Boolean  @default(false)
  attemptNumber   Int      @default(1)
  deliveredAt     DateTime @default(now())

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId])
  @@index([endpointId, deliveredAt])
  @@map("webhook_deliveries")
}

// ─── Wallet Passes (P0.1) ─────────────────────────────────────────────────────

// Caches generated pass metadata per card — actual pass files are generated on-demand.
model WalletPass {
  id           String   @id @default(cuid())
  cardId       String   @unique
  // Google Wallet: JWT object ID stored after first issuance
  googlePassId String?
  updatedAt    DateTime @updatedAt

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@map("wallet_passes")
}

// ─── Multi-Pipeline (Gap 11) ──────────────────────────────────────────────────

// A named pipeline owned by a user with custom stage definitions.
// The stages field is a JSON array of stage name strings, e.g.
// ["Lead In", "Qualified", "Proposal Sent", "Closed Won", "Closed Lost"]
model Pipeline {
  id          String   @id @default(cuid())
  ownerUserId String
  name        String   @db.VarChar(200)
  stages      Json     @default("[\"NEW\",\"CONTACTED\",\"QUALIFIED\",\"CLOSED\",\"LOST\"]")
  stageColors Json     @default("{}")
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner            User          @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  pipelineContacts CrmPipeline[]

  @@index([ownerUserId])
  // B7: Enforce only one default pipeline per user at the DB level.
  // When isDefault is false this unique pair (ownerUserId, false) could in theory
  // collide for many non-default pipelines, so we use a partial approach:
  // the application always sets isDefault=false on existing defaults before
  // setting a new one, and this unique constraint guarantees at most one
  // (ownerUserId, true) row exists.
  @@unique([ownerUserId, isDefault], name: "pipelines_owner_default_uidx", map: "pipelines_owner_default_uidx")
  @@map("pipelines")
}

// ─── CRM Extensions ───────────────────────────────────────────────────────────

// Threaded notes per contact (Gap 1)
model ContactNote {
  id          String   @id @default(cuid())
  contactId   String
  ownerUserId String
  content     String   @db.VarChar(10000)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  ownerUser User    @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@map("contact_notes")
}

// Custom field definitions per user (Gap 2)
model ContactCustomField {
  id           String          @id @default(cuid())
  ownerUserId  String
  label        String          @db.VarChar(100)
  fieldType    CustomFieldType @default(TEXT)
  options      Json            @default("[]")
  displayOrder Int             @default(0)
  createdAt    DateTime        @default(now())

  ownerUser User                       @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  values    ContactCustomFieldValue[]

  @@index([ownerUserId])
  @@map("contact_custom_fields")
}

// Custom field values per contact (Gap 2)
model ContactCustomFieldValue {
  id      String @id @default(cuid())
  contactId String
  fieldId   String
  value     String @db.VarChar(2000)

  contact Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  field   ContactCustomField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([contactId, fieldId])
  @@index([contactId])
  @@map("contact_custom_field_values")
}

// Deals / opportunities (Gap 3 + 13)
model Deal {
  id          String    @id @default(cuid())
  contactId   String
  ownerUserId String
  title       String    @db.VarChar(300)
  value       Decimal?  @db.Decimal(18, 2)
  currency    String    @default("USD") @db.VarChar(3)
  stage       DealStage @default(PROSPECT)
  probability Int?
  closeDate   DateTime?
  notes       String?   @db.VarChar(5000)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  ownerUser User    @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([ownerUserId])
  @@map("deals")
}

// Email templates (Gap 6)
model EmailTemplate {
  id          String   @id @default(cuid())
  ownerUserId String
  name        String   @db.VarChar(200)
  subject     String   @db.VarChar(998)
  body        String   @db.VarChar(50000)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerUser User @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([ownerUserId])
  @@map("email_templates")
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskType {
  CALL
  EMAIL
  MEETING
  TODO
  FOLLOW_UP
}

enum AutomationTriggerEvent {
  WHATSAPP_CLICKED
  WHATSAPP_AUTOMATION_TRIGGERED
  LEAD_CAPTURED
  BOOKING_COMPLETED
  PAYMENT_COMPLETED
}

enum AutomationActionType {
  CREATE_TASK
}

// Tasks / reminders (Gap 7)
model ContactTask {
  id          String        @id @default(cuid())
  contactId   String
  ownerUserId String
  title       String        @db.VarChar(500)
  dueAt       DateTime?
  completed   Boolean       @default(false)
  completedAt DateTime?
  priority    TaskPriority  @default(MEDIUM)
  type        TaskType      @default(TODO)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  ownerUser User    @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([ownerUserId, completed])
  @@map("contact_tasks")
}

model ContactAutomationRule {
  id                String                 @id @default(cuid())
  ownerUserId       String
  name              String                 @db.VarChar(160)
  triggerEvent      AutomationTriggerEvent
  actionType        AutomationActionType   @default(CREATE_TASK)
  taskTitle         String                 @db.VarChar(500)
  taskPriority      TaskPriority           @default(MEDIUM)
  taskType          TaskType               @default(FOLLOW_UP)
  delayMinutes      Int                    @default(1440)
  isActive          Boolean                @default(true)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  ownerUser User @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([ownerUserId, isActive])
  @@map("contact_automation_rules")
}

// ─── In-App Scheduling (Calendly replacement) ────────────────────────────────

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  NO_SHOW
}

enum BookingDepositStatus {
  INTENT_CREATED
  VERIFIED
  USED
  EXPIRED
}

enum DayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

/// An appointment type the owner publishes (e.g. "30-min intro call")
model AppointmentType {
  id           String   @id @default(cuid())
  ownerUserId  String
  /// Slug used in the public booking URL: /book/<cardHandle>/<slug>
  slug         String   @db.VarChar(100)
  name         String   @db.VarChar(200)
  description  String?  @db.VarChar(2000)
  durationMins Int      @default(30)
  /// Hex colour shown on the booking page
  color        String   @default("#0ea5e9") @db.VarChar(7)
  /// Maximum days in advance a visitor can book
  bufferDays   Int      @default(60)
  /// Minutes of buffer added after each meeting
  bufferAfterMins Int   @default(0)
  isActive     Boolean  @default(true)
  /// Optional meeting location / URL (e.g. Zoom link, office address)
  location     String?  @db.VarChar(500)
  /// IANA timezone for this appointment type, e.g. "America/New_York"
  timezone     String   @default("UTC") @db.VarChar(64)
  /// Optional crypto deposit required before confirming a booking
  depositEnabled Boolean @default(false)
  depositAmountUsdt String? @db.VarChar(32)
  /// CRITICAL-2: Soft-delete timestamp. Set instead of hard-deleting so that
  /// all related Booking rows (past and future) are preserved for audit/history.
  /// When non-null the type is hidden from all owner/public queries.
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownerUser         User               @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  availabilityRules AvailabilityRule[]
  bookings          Booking[]
  deposits          BookingDeposit[]
  questions         BookingQuestion[]

  @@unique([ownerUserId, slug])
  @@index([ownerUserId])
  @@map("appointment_types")
}

/// Weekly recurring availability window for an appointment type
model AvailabilityRule {
  id                String          @id @default(cuid())
  appointmentTypeId String
  dayOfWeek         DayOfWeek
  /// "HH:MM" in the owner's local time (stored as plain string, no TZ)
  startTime         String          @db.VarChar(5)
  endTime           String          @db.VarChar(5)

  appointmentType AppointmentType @relation(fields: [appointmentTypeId], references: [id], onDelete: Cascade)

  @@index([appointmentTypeId])
  @@map("availability_rules")
}

/// A visitor booking for a specific appointment type + time slot
model Booking {
  id                String        @id @default(cuid())
  appointmentTypeId String
  ownerUserId       String
  /// ISO-8601 start datetime (UTC stored)
  startAt           DateTime
  /// ISO-8601 end datetime derived from durationMins
  endAt             DateTime
  status            BookingStatus @default(CONFIRMED)
  /// Visitor details
  guestName         String        @db.VarChar(200)
  guestEmail        String        @db.VarChar(254)
  guestNotes        String?       @db.VarChar(2000)
  /// Owner-side cancel reason
  cancelReason      String?       @db.VarChar(500)
  /// Unique token used in cancellation / reschedule links
  token             String        @unique @default(cuid())
  /// HIGH-4: Expiry for the cancel/reschedule token. Set to startAt + 24h so
  /// that links in confirmation emails stop working after the appointment has
  /// passed. Null means no expiry (legacy rows before this field was added).
  tokenExpiresAt    DateTime?
  /// Set after a 24h-before reminder email is sent — prevents duplicate sends
  reminderSentAt    DateTime?
  /// Google Calendar event ID — stored after syncing booking to owner's calendar
  googleEventId     String?
  depositPaymentId  String?       @db.VarChar(100)
  depositTxHash     String?       @db.VarChar(66)
  depositAmountUsdt String?       @db.VarChar(32)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  /// CRITICAL-2: Restrict prevents hard-deleting an appointment type that still
  /// has bookings — the soft-delete path (deletedAt) is the intended delete path.
  appointmentType AppointmentType @relation(fields: [appointmentTypeId], references: [id], onDelete: Restrict)
  ownerUser       User            @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  answers         BookingAnswer[]

  @@index([ownerUserId, startAt])
  @@index([appointmentTypeId, startAt])
  @@index([token])
  @@map("bookings")
}

model BookingDeposit {
  id                String               @id @default(cuid())
  paymentId         String               @unique @db.VarChar(100)
  appointmentTypeId String
  ownerUserId       String
  guestName         String               @db.VarChar(120)
  guestEmail        String               @db.VarChar(254)
  walletAddress     String               @db.VarChar(42)
  recipientAddress  String               @db.VarChar(42)
  startAt           DateTime
  amountUsdt        String               @db.VarChar(32)
  amountRaw         String               @db.VarChar(64)
  tokenAddress      String               @db.VarChar(42)
  chainId           Int
  status            BookingDepositStatus @default(INTENT_CREATED)
  txHash            String?              @unique @db.VarChar(66)
  verifiedAt        DateTime?
  usedAt            DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  appointmentType AppointmentType @relation(fields: [appointmentTypeId], references: [id], onDelete: Cascade)
  ownerUser       User            @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([ownerUserId, status])
  @@index([appointmentTypeId, startAt])
  @@map("booking_deposits")
}

// ─── Booking Questions & Answers ─────────────────────────────────────────────

enum BookingQuestionType {
  TEXT
  TEXTAREA
  EMAIL
  PHONE
  SELECT
  CHECKBOX
}

/// A custom question attached to an appointment type shown on the booking page
model BookingQuestion {
  id                String              @id @default(cuid())
  appointmentTypeId String
  /// Display label shown to the guest, e.g. "What company are you from?"
  label             String              @db.VarChar(300)
  type              BookingQuestionType @default(TEXT)
  /// For SELECT type: JSON array of option strings, e.g. ["Sales","Support","Other"]
  options           String?             @db.VarChar(2000)
  required          Boolean             @default(false)
  /// Order in which questions appear on the booking page
  position          Int                 @default(0)
  createdAt         DateTime            @default(now())

  appointmentType AppointmentType  @relation(fields: [appointmentTypeId], references: [id], onDelete: Cascade)
  answers         BookingAnswer[]

  @@index([appointmentTypeId, position])
  @@map("booking_questions")
}

/// Guest's answer to a custom booking question, stored alongside the booking
model BookingAnswer {
  id         String   @id @default(cuid())
  bookingId  String
  questionId String
  value      String   @db.VarChar(5000)

  booking  Booking         @relation(fields: [bookingId],  references: [id], onDelete: Cascade)
  question BookingQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([bookingId, questionId])
  @@index([bookingId])
  @@map("booking_answers")
}

// ─── Google Calendar Integration ─────────────────────────────────────────────

/// OAuth2 tokens for a user's connected Google Calendar account
model GoogleCalendarConnection {
  id           String   @id @default(cuid())
  userId       String   @unique
  /// Google account email address
  googleEmail  String   @db.VarChar(254)
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  /// When the current accessToken expires
  expiresAt    DateTime
  /// Primary calendar ID to create events on (usually the google email)
  calendarId   String   @default("primary") @db.VarChar(254)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("google_calendar_connections")
}

// ─── Card Inbox: Messages ─────────────────────────────────────────────────────

/// A text message sent by any visitor to a card owner via the public card page
model CardMessage {
  id          String   @id @default(cuid())
  cardId      String
  senderName  String   @db.VarChar(200)
  senderEmail String?  @db.VarChar(254)
  message     String   @db.VarChar(5000)
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@index([cardId, createdAt])
  @@map("card_messages")
}

// ─── Card Inbox: Voice Notes ──────────────────────────────────────────────────

/// An audio voice note recorded by a visitor and uploaded to R2
model CardVoiceNote {
  id          String   @id @default(cuid())
  cardId      String
  senderName  String   @db.VarChar(200)
  senderEmail String?  @db.VarChar(254)
  audioUrl    String   @db.VarChar(2048)
  durationSec Int?
  mimeType    String   @db.VarChar(100)
  fileSize    Int?
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@index([cardId, createdAt])
  @@map("card_voice_notes")
}

// ─── Card Inbox: Dropbox Files ────────────────────────────────────────────────

/// A file dropped by a visitor via the card's public dropbox
model CardDropboxFile {
  id          String   @id @default(cuid())
  cardId      String
  senderName  String   @db.VarChar(200)
  senderEmail String?  @db.VarChar(254)
  fileName    String   @db.VarChar(500)
  fileUrl     String   @db.VarChar(2048)
  mimeType    String   @db.VarChar(100)
  fileSize    Int?
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@index([cardId, createdAt])
  @@map("card_dropbox_files")
}

// ─── CRM: Meeting Memories ────────────────────────────────────────────────────

/// A short memory/note tied to a contact, created during or after a meeting
model ContactMemory {
  id          String   @id @default(cuid())
  contactId   String
  ownerUserId String
  content     String   @db.VarChar(2000)
  createdAt   DateTime @default(now())

  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  ownerUser User    @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([ownerUserId])
  @@map("contact_memories")
}
