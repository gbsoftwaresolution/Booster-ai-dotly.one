generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Plan {
  FREE
  STARTER
  PRO
  BUSINESS
  AGENCY
  ENTERPRISE
}

enum BillingDuration {
  MONTHLY
  SIX_MONTHS
  ANNUAL
}

enum CardTemplate {
  MINIMAL
  BOLD
  CREATIVE
  CORPORATE
}

enum ContactStage {
  NEW
  CONTACTED
  QUALIFIED
  CLOSED
  LOST
}

enum AnalyticsEventType {
  VIEW
  CLICK
  SAVE
  LEAD_SUBMIT
}

enum SocialPlatform {
  LINKEDIN
  TWITTER
  INSTAGRAM
  GITHUB
  YOUTUBE
  TIKTOK
  WHATSAPP
  FACEBOOK
  CALENDLY
  CALCOM
  CUSTOM
}

enum MediaBlockType {
  VIDEO
  IMAGE
  AUDIO
  DOCUMENT
  HEADING
}

enum TeamRole {
  ADMIN
  MEMBER
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  TRIALING
}

enum DomainStatus {
  PENDING
  ACTIVE
  FAILED
}

enum LeadFieldType {
  TEXT
  EMAIL
  PHONE
  URL
  TEXTAREA
  SELECT
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id            String  @id @default(cuid())
  email         String  @unique
  name          String?
  avatarUrl     String?
  plan          Plan    @default(FREE)
  walletAddress String? @unique // crypto billing
  supabaseId    String? @unique // Supabase Auth user ID
  pushToken     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  cards           Card[]
  contacts        Contact[]
  subscription    Subscription?
  customDomains   CustomDomain[]
  ownedTeams      Team[]       @relation("TeamOwner")
  teamMemberships TeamMember[]
  auditLogs       AuditLog[]
  webhookEndpoints WebhookEndpoint[]

  @@map("users")
}

model Card {
  id         String       @id @default(cuid())
  userId     String
  handle     String       @unique
  templateId CardTemplate @default(MINIMAL)
  fields     Json         @default("{}")
  isActive   Boolean      @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme       CardTheme?
  socialLinks SocialLink[]
  mediaBlocks MediaBlock[]
  qrCode      QrCode?
  analytics   AnalyticsEvent[]
  contacts    Contact[]        @relation("ContactSourceCard")
  customDomains CustomDomain[]
  leadForm    LeadForm?
  walletPass  WalletPass?

  @@index([userId])
  @@map("cards")
}

model CardTheme {
  id                String  @id @default(cuid())
  cardId            String  @unique
  primaryColor      String  @default("#000000")
  secondaryColor    String  @default("#ffffff")
  fontFamily        String  @default("Inter")
  backgroundUrl     String?
  logoUrl           String?
  buttonStyle       String?
  socialButtonStyle String?

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@map("card_themes")
}

model SocialLink {
  id           String         @id @default(cuid())
  cardId       String
  platform     SocialPlatform
  url          String
  displayOrder Int            @default(0)

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@map("social_links")
}

model MediaBlock {
  id           String         @id @default(cuid())
  cardId       String
  type         MediaBlockType
  url          String?
  caption      String?
  altText      String?
  linkUrl      String?
  displayOrder Int            @default(0)
  mimeType     String?
  fileSize     Int?
  groupId      String?
  groupName    String?

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@map("media_blocks")
}

model QrCode {
  id          String @id @default(cuid())
  cardId      String @unique
  styleConfig Json   @default("{}")
  shortUrl    String

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@map("qr_codes")
}

model AnalyticsEvent {
  id        String             @id @default(cuid())
  cardId    String
  type      AnalyticsEventType
  metadata  Json               @default("{}")
  ipHash    String?
  country   String?
  device    String?
  referrer  String?
  createdAt DateTime           @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@index([cardId, type])
  @@index([cardId, createdAt])
  @@index([createdAt])
  @@map("analytics_events")
}

model Contact {
  id           String   @id @default(cuid())
  ownerUserId  String
  name         String
  email        String?
  phone        String?
  company      String?
  title        String?
  website      String?
  address      String?
  notes        String?
  tags         String[]
  sourceCardId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // AI Enrichment fields
  inferredIndustry    String?
  inferredCompanySize String?
  inferredSeniority   String?
  inferredLinkedIn    String?
  enrichmentScore     Int?
  enrichmentSummary   String?
  enrichedAt          DateTime?

  ownerUser       User              @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  sourceCard      Card?             @relation("ContactSourceCard", fields: [sourceCardId], references: [id], onDelete: SetNull)
  crmPipeline     CrmPipeline?
  emails          ContactEmail[]
  timeline        ContactTimeline[]
  leadSubmissions LeadSubmission[]

  @@unique([ownerUserId, email])
  @@index([ownerUserId])
  @@map("contacts")
}

model CrmPipeline {
  id          String       @id @default(cuid())
  contactId   String       @unique
  stage       ContactStage @default(NEW)
  ownerUserId String
  updatedAt   DateTime     @updatedAt

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([ownerUserId, stage])
  @@map("crm_pipeline")
}

model Subscription {
  id                     String             @id @default(cuid())
  userId                 String             @unique
  plan                   Plan               @default(FREE)
  status                 SubscriptionStatus @default(TRIALING)
  contractSubscriptionId String? // on-chain subscription ID
  txHash                 String? // on-chain activation transaction hash
  chainId                Int? // 137 = Polygon, 8453 = Base
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean            @default(false)

  // BoosterAI affiliate billing integration
  // Set when the subscription was purchased via BoosterAI's PaymentVault.
  // boosterAiOrderId  — the orderId returned by BoosterAI's POST /v1/orders
  // boosterAiPartnerId — the affiliate partner who referred this user (nullable
  //                      when the user purchased directly with no referral)
  boosterAiOrderId   String? @unique // BoosterAI ord_xxx order ID
  boosterAiPartnerId String? // numeric partnerId as string (BigInt safe)
  billingDuration    BillingDuration? // MONTHLY | SIX_MONTHS | ANNUAL
  amountUsdt         String? // exact USDT amount charged, e.g. "20.00"

  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([boosterAiOrderId])
  @@map("subscriptions")
}

model CustomDomain {
  id                String       @id @default(cuid())
  userId            String
  cardId            String?
  domain            String       @unique
  status            DomainStatus @default(PENDING)
  verificationToken String
  isVerified        Boolean      @default(false)
  sslStatus         String       @default("pending")
  txtRecord         String       @default("")
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card? @relation(fields: [cardId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([domain])
  @@map("custom_domains")
}

model Team {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique // URL-safe lowercase slug derived from name
  ownerUserId String
  brandConfig Json     @default("{}")
  brandLock   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner   User         @relation("TeamOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  members TeamMember[]
  invites TeamInvite[]

  @@index([ownerUserId])
  @@map("teams")
}

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  userId   String
  role     TeamRole @default(MEMBER)
  joinedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
  @@map("team_members")
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  action       String
  resource     String   @default("")
  resourceId   String?
  metadata     Json     @default("{}")
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model ContactEmail {
  id        String   @id @default(cuid())
  contactId String
  subject   String   @db.VarChar(998)
  body      String   @db.VarChar(5000)
  sentAt    DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@map("contact_emails")
}

model ContactTimeline {
  id        String   @id @default(cuid())
  contactId String
  event     String
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@map("contact_timeline")
}

model TeamInvite {
  id        String    @id @default(cuid())
  teamId    String
  email     String
  role      TeamRole  @default(MEMBER)
  token     String    @unique
  accepted  Boolean   @default(false)
  expiresAt DateTime
  createdAt DateTime  @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([email])
  @@map("team_invites")
}

// ─── Lead Capture Form (P0.3) ─────────────────────────────────────────────────

// One LeadForm per Card — defines the custom field schema shown on the public card.
model LeadForm {
  id          String      @id @default(cuid())
  cardId      String      @unique
  title       String      @default("Connect with me")
  description String      @default("Leave your details and they'll be in touch.")
  buttonText  String      @default("Connect")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  card        Card          @relation(fields: [cardId], references: [id], onDelete: Cascade)
  fields      LeadField[]
  submissions LeadSubmission[]

  @@map("lead_forms")
}

// Each row is one custom input field on the lead capture form.
model LeadField {
  id           String        @id @default(cuid())
  leadFormId   String
  label        String        @db.VarChar(100)
  fieldType    LeadFieldType @default(TEXT)
  placeholder  String?       @db.VarChar(200)
  required     Boolean       @default(false)
  displayOrder Int           @default(0)
  // For SELECT type — JSON array of option strings, e.g. ["Sales","Marketing","Engineering"]
  options      Json          @default("[]")

  leadForm LeadForm @relation(fields: [leadFormId], references: [id], onDelete: Cascade)

  @@index([leadFormId])
  @@map("lead_fields")
}

// One row per public lead form submission — stores the raw field answers.
// contactId links back to the Contact created at submission time (nullable
// for cases where the contact could not be created, e.g. duplicate email).
model LeadSubmission {
  id         String   @id @default(cuid())
  leadFormId String
  contactId  String?
  // JSON object mapping normalised field label → submitted value
  // e.g. { "name": "Jane", "company": "Acme", "interest": "Sales" }
  answers    Json     @default("{}")
  submittedAt DateTime @default(now())

  leadForm LeadForm @relation(fields: [leadFormId], references: [id], onDelete: Cascade)
  contact  Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([leadFormId])
  @@index([contactId])
  @@map("lead_submissions")
}

// ─── Outbound Webhooks (P0.2) ─────────────────────────────────────────────────

// A webhook endpoint registered by a user (e.g. Zapier catch-hook URL).
model WebhookEndpoint {
  id        String   @id @default(cuid())
  userId    String
  url       String   @db.VarChar(2048)
  // Comma-separated event names e.g. "lead.created,card.viewed"
  events    String[]
  secret    String   // HMAC-SHA256 signing secret (stored hashed in service, raw here for simplicity)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([userId])
  @@map("webhook_endpoints")
}

// Delivery log — one row per webhook fan-out attempt.
model WebhookDelivery {
  id              String   @id @default(cuid())
  endpointId      String
  event           String
  payload         Json
  statusCode      Int?
  responseBody    String?  @db.VarChar(2000)
  durationMs      Int?
  success         Boolean  @default(false)
  attemptNumber   Int      @default(1)
  deliveredAt     DateTime @default(now())

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId])
  @@index([endpointId, deliveredAt])
  @@map("webhook_deliveries")
}

// ─── Wallet Passes (P0.1) ─────────────────────────────────────────────────────

// Caches generated pass metadata per card — actual pass files are generated on-demand.
model WalletPass {
  id           String   @id @default(cuid())
  cardId       String   @unique
  // Google Wallet: JWT object ID stored after first issuance
  googlePassId String?
  updatedAt    DateTime @updatedAt

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@map("wallet_passes")
}
