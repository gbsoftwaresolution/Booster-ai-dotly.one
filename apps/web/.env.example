# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# API — public (client-side) and internal (server-side SSR/ISR)
NEXT_PUBLIC_API_URL=http://localhost:3001
# Internal API URL used by Next.js server components (may differ from the public URL in production)
# e.g. http://api:3001 when running in the same private network / Railway service
# server-api.ts reads API_URL first, then falls back to INTERNAL_API_URL — set either one.
# API_URL is the preferred name; INTERNAL_API_URL is accepted as an alias for backwards compatibility.
API_URL=http://localhost:3001
INTERNAL_API_URL=http://localhost:3001

# App public URL — used to build share links (card URLs, invite links, etc.)
# Both names are needed: middleware.ts reads NEXT_PUBLIC_APP_URL, other code uses NEXT_PUBLIC_WEB_URL
NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Canonical site URL used for card share meta tags and Open Graph (card/[handle]/page.tsx, ShareBar.tsx)
# In production set to https://dotly.one (or your custom domain)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# BoosterAI PaymentVault (Arbitrum One) — returned per-order by the API;
# set here as a client-side reference for the payment UI.
NEXT_PUBLIC_PAYMENT_VAULT_ADDRESS=0x952257d729e49707f7692B870fC93bf182824Fb2

# Error tracking (optional but recommended in production)
NEXT_PUBLIC_SENTRY_DSN=

# Analytics (optional)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Playwright authenticated plan-gate testing (optional)
PLAYWRIGHT_FREE_EMAIL=
PLAYWRIGHT_FREE_PASSWORD=
PLAYWRIGHT_STARTER_EMAIL=
PLAYWRIGHT_STARTER_PASSWORD=
PLAYWRIGHT_PRO_EMAIL=
PLAYWRIGHT_PRO_PASSWORD=
