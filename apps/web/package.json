{
  "name": "@dotly/web",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "next typegen && tsc --noEmit",
    "analyze": "ANALYZE=true next build",
    "verify": "npm run typecheck && npm run build",
    "test:e2e": "playwright test",
    "test:e2e:gates": "PLAYWRIGHT_FREE_STATE=.auth/free.json PLAYWRIGHT_STARTER_STATE=.auth/starter.json PLAYWRIGHT_PRO_STATE=.auth/pro.json playwright test e2e/plan-gates.spec.ts",
    "test:e2e:auth-states": "tsx e2e/generate-auth-states.ts all"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@dotly/types": "workspace:*",
    "@dotly/ui": "workspace:*",
    "@sentry/nextjs": "^10.47.0",
    "@supabase/ssr": "^0.3.0",
    "@supabase/supabase-js": "^2.43.5",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.3",
    "ethers": "^6.16.0",
    "jsqr": "^1.4.0",
    "lucide-react": "^1.8.0",
    "next": "15.5.15",
    "posthog-js": "^1.364.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-easy-crop": "^5.5.7",
    "react-icons": "^5.6.0",
    "recharts": "^2.12.7",
    "tailwind-merge": "^2.3.0",
    "viem": "^2.13.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^15.5.15",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/typography": "^0.5.13",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^20.14.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "15.5.15",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5"
  }
}
