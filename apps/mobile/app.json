{
  "expo": {
    "name": "Dotly — Digital Business Card",
    "slug": "dotly-one",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "dotly",
    "userInterfaceStyle": "automatic",
    "privacy": "unlisted",
    "owner": "dotly",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0ea5e9"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "one.dotly.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to scan business cards and capture profile photos",
        "NSPhotoLibraryUsageDescription": "Used to select a profile photo from your photo library",
        "NSContactsUsageDescription": "Used to save contacts to your address book",
        "NFCReaderUsageDescription": "Used to write your digital card to NFC tags"
      }
    },
    "android": {
      "package": "one.dotly.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0ea5e9"
      },
      "permissions": ["android.permission.NFC", "android.permission.CAMERA"]
    },
    "plugins": ["expo-router", "expo-secure-store", "expo-notifications"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "TODO_REPLACE_WITH_EAS_PROJECT_ID"
      }
    }
  }
}
