{
  "name": "@dotly/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "prebuild": "pnpm --filter @dotly/database run db:generate",
    "build": "nest build",
    "predev": "pnpm --filter @dotly/database run db:generate",
    "dev": "nest start --watch",
    "start": "node dist/src/main",
    "migrate:webhook-secrets": "tsx src/scripts/migrate-webhook-secrets.ts",
    "verify:metrics": "tsx src/scripts/verify-metrics.ts",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "pretypecheck": "pnpm --filter @dotly/database run db:generate",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:core-flow": "jest -- sales-link.service.spec.ts billing.service.spec.ts",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:load:sales-link": "k6 run load-tests/public-sales-link.js",
    "test:load:booking": "k6 run load-tests/sales-link-booking.js",
    "test:load:webhooks": "k6 run load-tests/payment-webhook-burst.js",
    "verify": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1025.0",
    "@aws-sdk/client-ses": "^3.1025.0",
    "@aws-sdk/s3-request-presigner": "^3.1025.0",
    "@dotly/database": "workspace:*",
    "@dotly/types": "workspace:*",
    "@nestjs/bull": "^11.0.4",
    "@nestjs/common": "^10.3.9",
    "@nestjs/config": "^3.2.2",
    "@nestjs/core": "^10.3.9",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.9",
    "@nestjs/schedule": "^4.0.2",
    "@nestjs/swagger": "^7.3.1",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^5.15.0",
    "@sentry/node": "^10.47.0",
    "bull": "^4.16.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ethers": "^6.16.0",
    "expo-server-sdk": "^6.1.0",
    "express": "^4.21.2",
    "form-data": "^4.0.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "mailgun.js": "^12.7.1",
    "nest-winston": "^1.10.2",
    "nestjs-throttler-storage-redis": "^0.5.1",
    "openai": "^6.33.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "stripe": "^18.5.0",
    "viem": "^2.13.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/testing": "^10.3.9",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/qrcode": "^1.5.6",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "typescript": "^5.4.5"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "tsconfig": {
            "module": "CommonJS",
            "moduleResolution": "node",
            "emitDecoratorMetadata": true,
            "experimentalDecorators": true,
            "strict": true,
            "strictNullChecks": true
          }
        }
      ]
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "moduleNameMapper": {
      "^@dotly/types$": "<rootDir>/../../../packages/types/src/index.ts",
      "^@dotly/database$": "<rootDir>/../../../packages/database/src/index.ts",
      "^expo-server-sdk$": "<rootDir>/__mocks__/expo-server-sdk.ts"
    },
    "testEnvironment": "node"
  }
}
