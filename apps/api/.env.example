# Database (local PostgreSQL)
DATABASE_URL=postgresql://YOUR_USER@localhost/dotly_one?host=/var/run/postgresql

# Supabase Auth
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=

# Redis
REDIS_URL=redis://localhost:6379

# Web app URL used for CORS and generated links
WEB_URL=http://localhost:3000
# Public API base URL used to build OAuth callback URLs and external links
API_URL=http://localhost:3001
# Optional extra allowed CORS origins, comma-separated
# CORS_ORIGINS=http://127.0.0.1:3000,https://preview.dotly.one

# Email — Mailgun (primary)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.yourdomain.com
MAILGUN_FROM_EMAIL=noreply@yourdomain.com

# Email — Amazon SES (fallback)
AWS_SES_ACCESS_KEY=
AWS_SES_SECRET_KEY=
AWS_SES_REGION=us-east-1
AWS_SES_FROM_EMAIL=noreply@yourdomain.com

# Cloudflare R2 Storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=dotly-uploads
R2_PUBLIC_URL=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
# Inbox direct-upload token signing secret (generate with: openssl rand -hex 32)
INBOX_UPLOAD_TOKEN_SECRET=

# Crypto Billing (Smart Contract — legacy DotlySubscription.sol)
POLYGON_RPC_URL=https://polygon-rpc.com
DOTLY_CONTRACT_ADDRESS=

# BoosterAI Affiliate Billing Integration
# The base URL of the BoosterAI API
BOOSTERAI_API_URL=https://api.boosterai.space
# Shared static API key used for Dotly → BoosterAI internal calls (x-dotly-api-key header)
BOOSTERAI_INTERNAL_API_KEY=
# BoosterAI planId numbers — must match the plan catalogue in BoosterAI's DB
BOOSTERAI_PLAN_ID_STARTER=1
BOOSTERAI_PLAN_ID_PRO=2
BOOSTERAI_PLAN_ID_BUSINESS=3
BOOSTERAI_PLAN_ID_AGENCY=4
BOOSTERAI_PLAN_ID_ENTERPRISE=5
# Default country code passed when creating orders (ISO 3166-1 alpha-2)
BOOSTERAI_COUNTRY_CODE=US
# Shared secret for BoosterAI → Dotly internal calls (x-boosterai-api-key header)
# Must match BOOSTERAI_DOTLY_CHECK_API_KEY in BoosterAI's env
# Generate with: openssl rand -hex 32
BOOSTERAI_DOTLY_API_KEY=

# App
PORT=3001
NODE_ENV=development
WEB_URL=http://localhost:3000
SENTRY_DSN=
SWAGGER_ENABLED=false

# Optional feature-specific secrets
# Google Calendar OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_STATE_SECRET=
WEBHOOK_SECRET_ENCRYPTION_KEY=
