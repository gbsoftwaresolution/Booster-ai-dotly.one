{
  "name": "dotly-one",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "build:api": "turbo build --filter=@dotly/api",
    "build:web": "turbo build --filter=web",
    "dev": "turbo dev --filter=!@dotly/mobile",
    "dev:all": "turbo dev",
    "dev:mobile": "turbo dev --filter=@dotly/mobile",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.9.4",
    "typescript": "^5.4.5",
    "prettier": "^3.3.2",
    "@types/node": "^20.14.2"
  },
  "engines": {
    "node": ">=20.18.1",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "braces": ">=3.0.3",
      "micromatch": ">=4.0.8",
      "path-to-regexp": ">=0.1.12",
      "semver": ">=7.5.4",
      "tough-cookie": ">=4.1.4",
      "ws": ">=8.17.1"
    }
  }
}
